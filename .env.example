# Portal signed-launch verification.
PORTAL_MODULE_LAUNCH_SECRET=change-me-long-random-shared-secret
PORTAL_MODULE_AUDIENCE=cypherpunk-archive
PORTAL_MODULE_SLUG=cypherpunk-archive
PORTAL_MODULE_ISSUER=https://portal.raidguild.org

# Local session cookie signing. Use a different long random value in production.
SESSION_SECRET=change-me-long-random-session-secret

# Public app URL used for Portal callback redirects in production.
APP_PUBLIC_URL=https://cypherpunk-archive-production.up.railway.app

# Link target for users launching through Portal.
PORTAL_MODULES_URL=https://portal.raidguild.org/modules
